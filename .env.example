# --- AI Debate Simulator Configuration ---

# The URL where the Ollama service is accessible.
# When running via Docker Compose, use 'http://ollama:11434'.
OLLAMA_BASE_URL=http://ollama:11434

# The name of the LLM model to use for generation and embeddings.
# Recommended: 'llama3:8b' or 'llama3.2'.
LLM_MODEL_NAME=llama3:8b

# Optional: Port for the FastAPI application (default: 8000)
# PORT=8000
